digraph macagent_v2 {
  rankdir=LR;
  labelloc="t";
  fontname="Helvetica-Bold";
  fontsize=18;
  label="macagent v2 — credential gateway + userspace egress proxy (laptop dev env)";
  node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled", fillcolor=white];
  edge [fontname="Helvetica", fontsize=9];
  compound=true;

  /* ───────────── Untrusted sandbox VM ───────────── */
  subgraph cluster_vm {
    label="Sandbox VM  (untrusted: repo code, deps, prompt-injection)";
    style="rounded,filled"; fillcolor="#fdecea"; color="#c0392b"; fontcolor="#c0392b"; fontname="Helvetica-Bold";
    claude   [label="claude --bare -p\n--dangerously-skip-permissions", fillcolor="#fadbd8"];
    tools    [label="npm / pip\n(deps)", fillcolor="#fadbd8"];
    nft      [label="nft PIN (root, pre-priv-drop)\nallow egress ONLY → :8088 and → :3128\nDROP 53 (no DNS) + everything else", shape=note, fillcolor="#f5b7b1"];
    venv     [label="env injected by broker:\nANTHROPIC_BASE_URL=http://GW:8088\nANTHROPIC_AUTH_TOKEN=tok_…  (NO real key)\nHTTPS_PROXY=http://GW:3128", shape=note, fillcolor="#fdebd0"];
  }

  /* ───────────── Host = laptop = TCB ───────────── */
  subgraph cluster_host {
    label="HOST · laptop (TCB) — userspace, no sudo";
    style="rounded,filled"; fillcolor="#eafaf1"; color="#1e8449"; fontcolor="#1e8449"; fontname="Helvetica-Bold";

    broker   [label="brokerd\nPOST /tasks  →  mint token, inject env,\nrun container, capture diff, host-side push", fillcolor="#d5f5e3"];
    realkey  [label="REAL ANTHROPIC_API_KEY\n(host env only — never enters VM)", shape=note, fillcolor="#abebc6"];

    gateway  [label="GATEWAY  :8088  (in-process)\nvalidate Bearer tok (exists / !expired / spent<budget)\nstrip Authorization → set X-Api-Key: REAL\nparse usage → spentUSD;  revoke on task end", fillcolor="#d5f5e3"];
    squid    [label="squid  :3128  (userspace)\nCONNECT allowlist by hostname\n(no TLS interception)", fillcolor="#d5f5e3"];
  }

  /* ───────────── Internet ───────────── */
  subgraph cluster_net {
    label="Internet";
    style="rounded,dashed"; color="#7f8c8d"; fontcolor="#7f8c8d"; fontname="Helvetica-Bold";
    anthropic [label="api.anthropic.com", fillcolor="#d6eaf8"];
    registries[label="registry.npmjs.org\npypi.org / files.pythonhosted.org", fillcolor="#d6eaf8"];
  }

  /* ── control plane (broker sets things up) ── */
  broker -> gateway [label="Mint(budget) → tok", style=dashed, color="#1e8449"];
  broker -> venv    [label="inject env + run", style=dashed, color="#1e8449", lhead=cluster_vm];
  realkey -> gateway [label="held here", style=dotted, color="#1e8449", arrowhead=none];

  /* ── model-API data path ── */
  claude   -> gateway   [label="HTTP  Bearer tok\n→ GW:8088", color="#c0392b", penwidth=2];
  gateway  -> anthropic [label="HTTPS  X-Api-Key: REAL", color="#1e8449", penwidth=2];

  /* ── package-registry data path ── */
  tools    -> squid     [label="CONNECT host\n→ GW:3128", color="#c0392b", penwidth=2];
  squid    -> registries[label="HTTPS (host allowlist)", color="#1e8449", penwidth=2];

  /* ── the pin governs both VM egress edges ── */
  nft -> claude [style=invis];
  nft -> tools  [style=invis];

  /* boundary caption */
  caption [shape=plaintext, fillcolor=none, style="", label="Trust boundary: only a per-task token + the task cross IN; only a git diff crosses OUT (host does the push)."];
  { rank=sink; caption; }
}
